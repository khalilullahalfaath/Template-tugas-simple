  note       = {Google-Books-{ID}: {AOhQAAAAMAAJ}},
  keywords   = {Computers / Artificial Intelligence / General, Computers / Computer Science, Computers / Data Science / Neural Networks, Mathematics / Logic, Mathematics / Set Theory}
